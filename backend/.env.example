# Copy to .env and fill in at least ONE provider's API key.
# 也可以全部留空，启动后在网页「设置」里配置 key/模型/回退链（更推荐给分享出去的部署者）。
#
# The LLM client tries providers in LLM_CHAIN order, falling through on failure.
# 每个供应商就是一个 OpenAI 兼容端点(base_url + api_key + model)，任何这类服务都可用。

# 回退链顺序（逗号分隔）。可填 nvidia / deepseek / openai / 或你自定义的 id
LLM_CHAIN=nvidia,deepseek

# --- NVIDIA Build (托管 DeepSeek 等模型, 有免费额度) ---
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_API_KEY=
NVIDIA_MODEL=deepseek-ai/deepseek-v4-flash

# --- DeepSeek 官方 ---
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# --- OpenAI (或任意 OpenAI 兼容服务) ---
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- ds2api: 可选, 自建的 OpenAI 兼容网关; 没有就留空/不用 ---
DS2API_BASE_URL=
DS2API_API_KEY=
DS2API_MODEL=

# Finnhub (免费档): 公司资料 + 实时报价 + 公司新闻。注册即得 https://finnhub.io
FINNHUB_API_KEY=

# Crawl4ai 登录态 profile 名（首次 python -m scraper.x_profile 创建）
X_PROFILE_NAME=x-stock-kol

# 抓取参数
SCRAPE_TWEET_LIMIT=30
SCRAPE_SCROLL_DELAY=2.5
SCRAPE_BATCH=10
